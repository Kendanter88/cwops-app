# Copy to .env and fill in. NEVER commit .env (it's gitignored).
SECRET_KEY=change-me-to-a-long-random-string

# Leave blank to use the default SQLite db at instance/app.db
DATABASE_URL=

# Set to 1 in production (HTTPS) so the session cookie gets the Secure flag.
CWOPS_COOKIE_SECURE=0

# Public URL used to build invite/activation links in emails.
BASE_URL=http://127.0.0.1:5000

# Gmail SMTP — use a Google App Password (Account > Security > App passwords),
# NOT your normal Gmail password. App passwords are shown as 4 groups of 4;
# enter them here without spaces.
GMAIL_USER=den4ve@gmail.com
GMAIL_APP_PASSWORD=
MAIL_FROM=den4ve@gmail.com

# While 1, all outbound mail is redirected to SAFE_MODE_TO instead of the real
# recipient — keep it on until you've tested the invite/cert email flow.
CWOPS_SAFE_MODE=1
SAFE_MODE_TO=den4ve@gmail.com

# Hours an account-activation invite link stays valid.
INVITE_TTL_HOURS=72
